Options -Indexes
RewriteEngine On

RewriteRule ^(?:config|core|includes|uploads|vendor)(?:/|$) - [F,L]
RewriteRule ^(?:composer\.(?:json|lock)|schema\.sql|seed\.php|test-mail\.php|README\.md)$ - [F,L]

RewriteCond %{REQUEST_URI} !/public/
RewriteCond %{REQUEST_URI} !/portal/
RewriteRule ^$ public/ [L]
RewriteCond %{REQUEST_URI} !/public/
RewriteCond %{REQUEST_URI} !/portal/
RewriteRule ^(.*)$ public/$1 [L]
